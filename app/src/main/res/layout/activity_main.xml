<?xml version="1.0" encoding="utf-8"?>
<!-- Place at: app/src/main/res/layout/activity_main.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="360° Bird's Eye View — FB-SSEM / Jetson Nano"
        android:textColor="#00DCDC"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="10dp"/>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:indeterminate="true"
        android:visibility="gone"
        android:indeterminateTint="#00DC00"/>

    <TextView
        android:id="@+id/textStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Initialising..."
        android:textColor="#aaaaaa"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"/>

    <TextView
        android:id="@+id/textTiming"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#666666"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:paddingBottom="6dp"/>

    <!-- BEV display — takes all remaining space -->
    <ImageView
        android:id="@+id/imageViewBev"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:background="#000000"
        android:contentDescription="360 Bird's Eye View"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="10dp">

        <Button
            android:id="@+id/btnCompute"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Compute BEV"
            android:backgroundTint="#00AA00"
            android:textColor="#ffffff"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnGtCompare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Show GT BEV"
            android:backgroundTint="#0055AA"
            android:textColor="#ffffff"
            android:enabled="false"
            android:layout_marginStart="6dp"/>

    </LinearLayout>

</LinearLayout>
